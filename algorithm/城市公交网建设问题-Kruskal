#include<stdio.h>
#include<stdlib.h>

struct edge{
	int i,j,w;
};

int cmp(const void * a,const void *b){
	return ((struct edge*)a)->w-((struct edge*)b)->w;
}

int main(){
	int n,e;
	scanf("%d %d",&n,&e);
	int i,o;
	struct edge E[e];
	for(i=0;i<e;i++){
		scanf("%d %d %d",&E[i].i,&E[i].j,&E[i].w);
	}
	qsort(E,e,sizeof(struct edge),cmp);
	int sum=0;
	int S[n+1];
	int temp=0;
	for(i=0;i<n+1;i++){
		S[i]=i;
	}
	int cont=0;
	for(i=0;i<e&&cont<n-1;i++){
		if(S[E[i].i]==S[E[i].j]){
			continue;
		}else if(S[E[i].j]!=S[E[i].i]){
			if(S[E[i].i]<S[E[i].j]){
				temp=S[E[i].j];
				for(o=1;o<n+1;o++){
					if(S[o]==temp){
						S[o]=S[E[i].i];
					}
				}
			}else{
				temp=S[E[i].i];
				for(o=1;o<n+1;o++){
					if(S[o]==temp){
						S[o]=S[E[i].j];
					}
				}
			}
		}
		sum+=E[i].w;
		cont++;
	}
	printf("%d\n",sum);
	return 0;
}
