#include<stdio.h>
int main(){
	int n,m;
	scanf("%d %d",&n,&m);
	int i,o,j;
	int D[n+1][n+1];
	int P[n+1][n+1];
	
	//初始化 
	for(i=1;i<n+1;i++){
		for(o=1;o<n+1;o++){
			D[i][o]=10000;
			P[i][o]=0;
			if(i==o){
				D[i][o]=0;
			}
		}
	}
	//输入  
	int a,b,c;
	for(i=1;i<m+1;i++){
		scanf("%d %d %d",&a,&b,&c);
		D[a][b]=c;
		D[b][a]=c;
	}
	//开始遍历迭代
	for(j=1;j<n+1;j++){//zhonjan
		for(i=1;i<n+1;i++){//hang
			if(i==j){
				continue;
			}
			for(o=1;o<n+1;o++){//lie
				if(i==o||o==j){
					continue;
				}
				if(D[i][o]>D[i][j]+D[j][o]){
					D[i][o]=D[i][j]+D[j][o];
					P[i][o]=j;	
				}
			}
		}
	}
	
	printf("%d\n",D[1][n]);
	
	return 0;
}
