//离散应用题。接触新东西了
//思路：Dijkstra贪心，每一步找目前最优解。因为确定了源点是1，从1开始找离1最近的，找到这个点之后，标记一下这个点，表示这个点已经走过了，不能走回头路。
//把这个点作为中转点，看其他的如果经过这个点是不是比直接连更近（加权的，不是现实生活中直达和转机的关系）。[a-c]>[a-b]+[b-c];
//如果更近了，那么就更新一下这些点离源点目前最短距离。然后再看一下更新后除了已经走到了的这个点，哪个点最近。
//因为是重复步骤，所以用循环。找到所有最近点之后就算结束。也就是找n-1次。
//根据这个思路：我们需要：每个点之间的距离（二维数组），目前每个点目前离1的最近距离（数组），已经选了的标记（标记数组）。
//因为要找最小值，要遍历，所以我们还需要一个temp来存储那个找到的最小点。
//错误：初始化时i到i的距离要设为0；
//输入权值时是要对称传入。（是对称矩阵）


#include<stdio.h>
int main(){
	int n,m;
	scanf("%d %d",&n,&m);
	int i,o;
	int D[n+1][n+1];
	//初始化 
	for(i=1;i<n+1;i++){
		for(o=1;o<n+1;o++){
			D[i][o]=10000;
			if(i==o){
				D[i][o]=0;
			}
		}
	}
	//输入 
	int a,b,c;
	for(i=1;i<m+1;i++){
		scanf("%d %d %d",&a,&b,&c);
		D[a][b]=c;
		D[b][a]=c;
	}
	//初始化目前源点(1)到各个点的最短距离
	int Q[n+1];
	for(i=1;i<n+1;i++){
		Q[i]=D[1][i];
	}
	//初始化目前已选点标记
	int S[n+1];
	S[1]=1;
	for(i=2;i<n-1;i++){
		S[i]=0;
	} 
	//开始贪
	int cnt=n-1;
	int min=100000;
	int temp=0;
	while(cnt--){
		min=100000;
		for(i=1;i<n+1;i++){
			if(S[i]!=1&&Q[i]<min){
				min=Q[i];
				temp=i;
			}
		}
		S[temp]=1;
		for(i=1;i<n+1;i++){
			if(S[i]!=1&&Q[i]>Q[temp]+D[temp][i]){
				Q[i]=Q[temp]+D[temp][i];
			}
		}
		
	}
	printf("%d\n",Q[n]);
	
	return 0;
}
