//因为不是很大的数，枚举就行了
//为了方便，把a左移（a变大）和右移（b变大）一起算了，但是一个正值一个负值。
//读取输入a+b=c，直接写就行，scanf会根据格式自动匹配



#include<stdio.h>
int main(){
	int k;
	scanf("%d",&k);
	while(k--){
		int a,b,c;
		scanf("%d+%d=%d",&a,&b,&c);
		int i;
		int arr,brr;
		int temp=1;
		int cnt=0;
		for(i=0;temp*a<c||b*temp<c;i++){
			if(a*temp+b==c){
				cnt=i;
				break;
			}
			if(b*temp+a==c){
				cnt=-i;
				break;
			}
			temp*=10;
		}
		printf("%d\n",cnt);
	}
	return 0;
} 
