#include<string.h>
int main(){
	int n,m;
	while(scanf("%d %d",&n,&m),n||m){
		int a[n];
		int i;
		for(i=0;i<n;i++){
			scanf("%d",&a[i]);
		}
		int max=0;
		int sum=0;
		for(i=0;i<m;i++){
			sum+=a[i];
		}
		max=sum;
		for(i=1;i<=n-m;i++){
			if(sum-a[i-1]+a[i+m-1]>max){
				max=sum-a[i-1]+a[i+m-1];
			}
			sum=sum-a[i-1]+a[i+m-1];
			
		}
		printf("%d\n",max);
	}
	return 0;
}
