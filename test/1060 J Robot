//注意这里是移动，所以回原点只会是上=下，左等于右，一定要东一个方向，那么只能与其相对的那个是0；


#include<stdio.h>
#include<stdlib.h>
int main(){
    char str[201];
    while(scanf("%s",str)!=EOF){
        int l=strlen(str);
        int n11=0,n12=0,n21=0,n22=0;
        int i;
        for(i=0;i<l;i++){
            if(str[i]=='U'){
                n11++;
            }else if(str[i]=='D'){
                n12++;
            }else if(str[i]=='L'){
                n21++;
            }else if(str[i]=='R'){
                n22++;
            }
        }
        if(n11>n12){
            int temp=n11;
            n11=n12;
            n12=temp;
        }
        if(n21>n22){
            int temp=n21;
            n21=n22;
            n22=temp;
        }
        if(n21==0&&n11+n22==n12){
            puts("Yes");
        }else if(n11==0&&n21+n12==n22){
            puts("Yes");
        }else{
            puts("No");
        }
    }
    return 0;
}
