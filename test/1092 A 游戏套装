//首先是滑动窗口不走回头路
//两类，一类是在目前最短再找出来的后面比现在先到=5，遍历会到，其他省略
//一类是和现在最短有重叠。两种情况，这个在现在这个区间里先到5了，矛盾，因为先到五，这个不就成为现在了吗
//一种是最后一个成5在现在外部，如果离得比较远，那么l肯定比现在登记的区间小，不算也没事，如果是紧紧挨着，因为这个最前面那个会被删，所以再极端一定刚好到删了啊合格的前面之后，不能删了，也是小-大《大减小
//所以大胆删，我滑动窗口不回头 



#include<stdio.h>
#include<stdlib.h>
#include<string.h>

int main(){
    int n,m;
    scanf("%d %d",&n,&m);
    char arr[100005][10];
    int i,l=0;
    for(i=0;i<n;i++){
        scanf("%s",arr[i]);
    }
    int str[n][2];
    for(i=0;i<n;i++){
        str[i][1] = arr[i][0] - 'A';
        str[i][0] = atoi(arr[i]+1);
    }

    int pr = 0, pl = 0;
    int min_len = 1000000;

    int s[1005][5] = {0};
    int cnt[1005] = {0};

    for(i=0;i<n;i++){
        if(s[str[i][0]][str[i][1]] == 0){
            cnt[str[i][0]]++;
        }
        s[str[i][0]][str[i][1]]++;

        while(cnt[str[i][0]] == 5){
            int cur_len = i - l + 1;
            if(cur_len < min_len){
                min_len = cur_len;
                pl = l + 1;
                pr = i + 1;
            }

            s[str[l][0]][str[l][1]]--;
            if(s[str[l][0]][str[l][1]] == 0){
                cnt[str[l][0]]--;
            }
            l++;
        }
    }

    printf("%d %d\n",pl,pr);
    return 0;
}
