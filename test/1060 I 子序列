//本来在想是靠计数a>=b来但是还有一个重要的顺序条件
//从0位开始，对不上一位就把a中这一位删了，下面的补上，如果最后长度<lenb了就是No，如果顺利的对完了，那就是Yes


#include<stdio.h>
#include<string.h>
int sss(char bi[],char sm[],int n1,int n2){
    int i,o;
    int arr=0;
    for(i=0;i<n1;i++){
        next:
        if(sm[i]==bi[i]){
            if(i==n1-1){
                arr=1;
                break;
            }
            continue;
        }else{
            for(o=0;i+o<n2;o++){
                bi[i+o]=bi[i+o+1];
            }
            //这里因为是预留了一个停止符号的位置，所以是对的。 
            n2=strlen(bi);
            if(n2<n1){
                break;
            }
            goto next;
        }
    }
    return arr;
}
int main(){
    int  t;
    scanf("%d",&t);
    while(t--){
        char a[201];
        char b[201];
        scanf("%s",a);
        scanf("%s",b);
        int na=strlen(a);
        int nb=strlen(b);
        int brr=0;
        brr=sss(a,b,nb,na);
        if(brr){
            puts("Yes");
        }else{
            puts("No");
        }
    }
    return 0;
}
