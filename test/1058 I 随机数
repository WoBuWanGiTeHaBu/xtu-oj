//雾:Xn是模m的余数，所以不是一直增大的 
//思路，因为Xn是。。。。，所以周期最大为m，超过m一定会有重复余数，之后都是循环，所以就看这m次能不能把0-m所有值都找到
//可以用计数，也可以用寻找有没有还为0的；
//错误：NO/No


#include<stdio.h>

int main(){
	long long a,c,m;
	while(scanf("%lld %lld %lld",&a,&c,&m)!=EOF){
		int arr[m];
		memset(arr,0,sizeof(arr));
		int cnt=1;
		int i;
		int S[m];
		memset(S,0,sizeof(S));
		S[0]=1;
		for(i=0;i<m-1;i++){
			arr[i+1]=(a*arr[i]+c)%m;
			if(S[arr[i+1]]==0){
				cnt++;
			}
      S[arr[i+1]]==1;//其实我一开始忘记写这个了，结果没写也AC了
		}
		if(cnt==m){
			printf("Yes\n");
		}else{
			printf("No\n");
		}
		
	}
	
	return 0;
}
