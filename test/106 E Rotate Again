//和花朵那个类似。但是这里的子矩阵的两种情况是：外围2+内圈2  外围3+内圈1
//所以先读取这个矩阵，然后再根据顺序把这些读成上次那种一维的，然后是一样的手法；



#include<stdio.h>
int main()
{
    int T;
    scanf("%d",&T);
     
    while(T--)
    {
        int max=0;
        int a[4][4]={0};
            int i,j;
            for(i=0;i<4;i++)
            {
                for(j=0;j<4;j++)
                {
                    scanf("%d",&a[i][j]);   
                }
                 
            }
             
            int num=12;
            int brr=0;
            int b=0;
            while(num--)
            {
                b=a[0][3];
                for(i=2;i>=0;i--)
                {
                    a[0][i+1]=a[0][i];  
                }
                for(i=0;i<3;i++)
                {
                    a[i][0]=a[i+1][0];
                }
                for(i=0;i<3;i++)
                {
                    a[3][i]=a[3][i+1];
                }
                for(i=2;i>=0;i--)
                {
                         
                    a[i+1][3]=a[i][3];
                     
                } 
                a[1][3]=b;
                for(i=0;i<3;i++)
                {
                    for(j=0;j<3;j++)
                    {
                        brr=a[i][j]+a[i+1][j+1]+a[i+1][j]+a[i][j+1];
                        if(brr>max)
                        {
                            max=brr;
                        }
                    }
                }
                 
                 
            }   
        printf("%d\n",max); 
    }
     
     
return 0;   
  
}
