#思路：根据三角形两边之和一定大于第三边用ifelse
#错误：
#  没说三角形的三个边大小是整形
#  改了类型没改printf里面的%d
#  究极大错误：复制的时候没有选中'.'
#代码：

#include<stdio.h>
#include<math.h>

int main(){
    float a,b,c;
    scanf("%f %f %f",&a,&b,&c);
    if(a+b>c&&a+c>b&&b+c>a){
        double p=(a+b+c)/2;
        printf("%.2f",sqrt(p*(p-a)*(p-b)*(p-c)));
    }else{
        
        printf("Not a triangle.");
    }
    
    
    return 0;
}
