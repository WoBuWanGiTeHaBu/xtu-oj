#include<stdio.h>
typedef long long ll;
int main(){
    int T;
    scanf("%d",&T);
    while(T--){
        ll n,i,o;
        scanf("%d",&n);
        ll temp=0;
        ll m=0;
        for(i=0;i<n;i++){
            temp=n-i;
            for(o=0;o<10;o++){
                m+=temp%10;
                temp/=10;
                if(temp==0){
                    break;
                }
            }
            if((n-i)%m==0){
                printf("%d\n",n-i);
                break;
            }else{
                m=0;
            }
        }
    }
    return 0;
}
