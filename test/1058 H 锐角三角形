//循环i，o，j混用，而且直接用了i，oj，忘记要访问数组了


#include<stdio.h>

int main(){
	int k;
	scanf("%d",&k);
	while(k--){
		int n;
		scanf("%d",&n);
		int a[n];
		int i,o,j;
		for(i=0;i<n;i++){
			scanf("%d",&a[i]);
		}
		int cnt=0;
		for(i=0;i<n;i++){
			for(o=i+1;o<n;o++){
				for(j=o+1;j<n;j++){
					if(a[i]+a[o]>a[j]&&a[i]+a[j]>a[o]&&a[o]+a[j]>a[i]){
						if(a[i]*a[i]+a[o]*a[o]>a[j]*a[j]&&a[i]*a[i]+a[j]*a[j]>a[o]*a[o]&&a[j]*a[j]+a[o]*a[o]>a[i]*a[i]){
							cnt++;
						}
					}
				}
			}
		}
		printf("%d\n",cnt);
	}
	
	return 0;
}
