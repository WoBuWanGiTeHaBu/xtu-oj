#include <stdio.h>
#include <stdlib.h>
 
// 定义结构体存储a和b的原始值，避免浮点数精度误差
typedef struct {
    long long a;  
    long long b;
} Ratio;
 
Ratio c[100001];  // 存储所有(a,b)对的数组
int mid;          
 
// qsort的自定义比较函数：按 a/b 升序排序（用整数交叉乘法避免浮点误差）
int cmp(const void *x, const void *y) {
    
    Ratio *rx = (Ratio*)x;
    Ratio *ry = (Ratio*)y;
    
    // 等价于 a1*b2 < a2*b1
    long long left = rx->a * ry->b;   // a1*b2
    long long right = ry->a * rx->b;  // a2*b1
    
    // qsort规则：返回-1(x在前)、1(x在后)、0(相等)
    if (left < right) return -1;
    if (left > right) return 1;
    return 0;
}
 
// 二分查找：在区间[l, r]中找第一个满足 c[now].a*c[mid].a > c[now].b*c[mid].b 的下标
int find_first(int l, int r, int now) {
    int ans = r + 1;  
    while (l <= r) {
        // 计算中点：l + (r-l)/2 避免 l+r 溢出int范围
        mid = l + (r - l) / 2;
        
        // 核心判断：a1*a2 > b1*b2
        long long val = c[now].a * c[mid].a - c[now].b * c[mid].b;
        
        if (val > 0) {          // 满足条件，尝试找更左侧的位置
            ans = mid;
            r = mid - 1;
        } else {                // 不满足条件，向右找
            l = mid + 1;
        }
    }
    return ans;  // 返回第一个满足条件的下标（无则返回r+1）
}
 
int main() {
    int n;
    scanf("%d", &n);
 
    // 读取所有a值（分子）
    for (int i = 1; i <= n; i++) {
        scanf("%lld", &c[i].a);
    }
    // 读取所有b值（分母），与对应a值组成Ratio结构体
    for (int i = 1; i <= n; i++) {
        scanf("%lld", &c[i].b);
    }
 
    // 对c数组从下标1开始的n个元素排序，排序规则为cmp函数
    qsort(c + 1, n, sizeof(Ratio), cmp);
 
    long long count = 0;  // 统计满足条件的数对数量
    // 遍历每个元素i，只找i右侧的j(i<j)满足条件
    for (int i = 1; i < n; i++) {
        // 二分查找区间为[i+1, n]，确保j > i
        int pos = find_first(i + 1, n, i);
        // 若pos有效（<=n），则pos到n的所有j都满足条件，数量为n - pos + 1
        if (pos <= n) {
            count += n - pos + 1;
        }
    }
    printf("%lld\n", count);
    return 0;
}
