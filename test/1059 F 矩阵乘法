#include<stdio.h>
int main(){
    int K;
    scanf("%d",&K);
    while(K--){
        int n,m,k;
        scanf("%d %d",&n,&k);
        int a[n][k];
        int i,o,j;
        for(i=0;i<n;i++){
            for(o=0;o<k;o++){
                scanf("%d",&a[i][o]);
            }
        }
        scanf("%d %d",&k,&m);
        int b[k][m];
        for(i=0;i<k;i++){
            for(o=0;o<m;o++){
                scanf("%d",&b[i][o]);
            }
        }
        int c[n][m];
        for(i=0;i<n;i++){
            for(o=0;o<m;o++){
                c[i][o]=0;
            }
        }
        for(i=0;i<n;i++){
            for(o=0;o<m;o++){
                for(j=0;j<k;j++){
                    c[i][o]+=a[i][j]*b[j][o];
                }
            }
        }
        for(i=0;i<n;i++){
            for(o=0;o<m;o++){
                printf("%d",c[i][o]);
                if(o<m-1){
                    printf(" ");
                }
             
            }
            printf("\n");
        }   
    }
    return 0;
}
