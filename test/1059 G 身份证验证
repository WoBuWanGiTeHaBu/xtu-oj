//分别读取风险太大，不如老老实实都用char

#include<stdio.h>
typedef long long ll;
int main(){
    int K;
    scanf("%d",&K);
    while(K--){
        int i;
        char num[20];
        scanf("%s",num);
        int cont=1;
        int yu=0;
        for(i=17;i>=0;i--){
            if(num[i]=='X'){
                yu+=10*cont%11;
                cont*=2;
                continue;
            }
            yu+=(num[i]-'0')*cont%11;
            cont*=2;
        }
        yu%=11;
        if(yu==1){
            puts("Yes");
        }else{
            puts("No");
        }
    }
    return 0;
}
