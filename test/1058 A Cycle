
//思路：用整数枚举 ，看看强制转换后是不是等于自己，是就是整数/
//这里从1开始，到r结束（不包含)实际上就是在求不含四个数轴上的整数点的1/4。 




#include<stdio.h>
#include<math.h>
int main(){
    int t;
    scanf("%d",&t);
    while(t--){
        int r;
        scanf("%d",&r);
        int i;
        int cnt=0;
        for(i=1;i<r;i++){
            if(sqrt(r*r-i*i)==(int)sqrt(r*r-i*i)){
                cnt++;
            }
        }
        cnt*=4;
        cnt+=4;
        printf("%d\n",cnt);
    }    
    return 0;
}
