//把最容易的先判断了，可以方便一点


#include<stdio.h>
#include<math.h>
int main(){
    long long K;
    scanf("%lld",&K);
    while(K--){
        int x,y,z;
        int arr=1;
        scanf("%d %d",&x,&y);
        if(x==y){
            puts("None");
            continue;
        }
        if(x<y){
            int t=x;
            x=y;
            y=t;
        }
        x*=x;
        y*=y;
        z=sqrt(x-y);
        if(z*z==x-y){
            printf("%d\n",z);
            continue;
        }
        z=sqrt(x+y);
        if(z*z==(x+y)){
            printf("%d\n",z);
            continue;
        }
        if(arr){
            puts("None");
        }
    }
    return 0;
}
