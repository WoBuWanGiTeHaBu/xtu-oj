//和列素数表的思路有一点点类似，都是找到那个数之后，把这个数的所有倍数都抹去（把这个因子除干净）
//而且不用考虑cnt/i能不能除尽，因为cnt最开始要*n； 

#include<stdio.h>
#include<math.h>
typedef long long ll;
int main(){
    ll n;
    while(scanf("%lld",&n),n){
        ll temp=n;
        if(n==1){
            printf("0\n");
            continue;
        }
        ll cnt=n;
        ll i=0;
        ll b=sqrt(n);
        int arr=0;
        for(i=2;i<=b;i++){
            if(temp%i==0){
                cnt=cnt/i*(i-1);
                while(temp%i==0){
                    temp/=i;
                }
            }
             
        }
        if(temp>1){
            cnt=cnt/temp*(temp-1);
        }
        printf("%lld\n",cnt);
    }
     
    return 0;
}
