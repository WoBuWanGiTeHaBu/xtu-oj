//思路：先按列来确定这一列能不能涂红，能就加到sum上，然后记下能涂红的列数cnt。
//然后按行来确定能不能涂红，同上，但是这里需要减去之前按列来已经涂红了的，（加到sum上的：每一行要涂红的-cnt）。
//如果按照传统二维数组需要进行查找比较麻烦，所以直接建立两个标记数组。简化过程。

#include<stdio.h>
#include<string.h>
int main(){
    int t;
    scanf("%d",&t);
    while(t--){
        int m,n,k;
        scanf("%d %d %d",&m,&n,&k);
        int i,o;
        int r[m+1];
        int c[n+1];
        memset(r,0,sizeof(r));
        memset(c,0,sizeof(c));
        int x,y;
        for(i=0;i<k;i++){
            scanf("%d %d",&x,&y);
            r[x]=1;
            c[y]=1;
        }
        int cnt=0;
        int sum=0;
        for(i=0;i<m;i++){
            if(r[i+1]==0){
                sum+=n;
                cnt++;
            }
        }
        for(i=0;i<n;i++){
            if(c[i+1]==0){
                sum+=m-cnt;
            }
        }
        printf("%d\n",sum);
    }
    
    return 0;
}
