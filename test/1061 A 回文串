//若以中间为起始指针地点，那么后续更新指针初始值时不好判断（不知道是偶数个加一个成奇数个，还是加两个维持偶数等等）
//所以就反转一下，从外往内判断，自动识别mid。
//判断是否为保留部分和要加几个：内层如果相等到结尾那就是保留部分。要加的就是这个部分（a【i+o】）之外（左边）的几个所以就是i（因为i从0开始，不需要再减1）


#include<stdio.h>
#include<string.h> 
int main(){
    int t;
    scanf("%d",&t);
    while(t--){
        char a[2001];
        scanf("%s",a);
        int i=0,o=0;
        int n=strlen(a);
        int arr=0;
        for(i=0;i<n;i++){
            for(o=0;i+o<=n-o;o++){
                if(a[i+o]==a[n-1-o]){
                    if(i+o>=n-1-o){
                        arr=1;
                        goto next;
                    }
                    continue;
                }else{
                    break;
                }
            }
        }
        next:
            printf("%d\n",i);
         
    }
    return 0;
}
