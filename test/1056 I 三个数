//思路：因为加减乘除实际上是两种类型，所以就考虑两种。
//因为范围已经确定所以，要归零只能考虑-
//所以一定得有最大值 
//错误：不考虑最大值，直接考虑可以减的类型更适合。
//因为还有特殊值1；1*a=a;考虑最大值还需卡考虑是>= 


#include<stdio.h>
#include<math.h>
int main(){
	int n;
	scanf("%d",&n);
	while(n--){
		int a,b,c;
		scanf("%d %d %d",&a,&b,&c);
		int temp=0;
		if(a>=b&&a>=c){
			if(a==b+c||a==b*c){
				temp=1;
			}
		}else if(b>=a&&b>=c){
			if(b==a+c||b==a*c){
				temp=1;
			}
		}else if(c>=a&&c>=b){
			if(c==b+a||c==a*b){
				temp=1;
			}
		}

		
		if(temp){
			printf("Yes\n");
		}else{
			printf("No\n");
		}
		
	}
	
	
	return 0;
}
