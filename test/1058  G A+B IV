//因为不是特别大的数直接枚举去找就行。
//为了更方便，把a增大和b增大放到一起算。只不过b增大算负值。


#include<stdio.h>
int main(){
	int k;
	scanf("%d",&k);
	while(k--){
		int a,b,c;
		scanf("%d+%d=%d",&a,&b,&c);
		int i;
		int arr,brr;
		int temp=1;
		int cnt=0;
		for(i=0;temp*a<c||b*temp<c;i++){
			if(a*temp+b==c){
				cnt=i;
				break;
			}
			if(b*temp+a==c){
				cnt=-i;
				break;
			}
			temp*=10;
		}
		printf("%d\n",cnt);
	}
	return 0;
} 
