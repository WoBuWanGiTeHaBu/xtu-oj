//看到这种题应激了一下，主观觉得时间会超限，然后开始考虑素数表，然后发现其实暴力就行了
//暴力也是有技法的暴力。因为相加之和都是对称的，而且a<b所有遍历到C/2就行了
//错误：我把break写我的判定的前面了，导致输出永远None。



#include<stdio.h>

int main(){
	int k;
	scanf("%d",&k);
	while(k--){
		int c,d;
		int a,b;
		scanf("%d %d",&c,&d);
		int i;
		int temp=0;
		for(i=0;i<c/2+1;i++){
			a=i;
			b=c-a;
			if(a*b==d){
				temp=1;
				break;
			}
		}
		if(temp){
			printf("%d %d\n",a,b);
		}else{
			printf("None\n");
		}
		
		
	}



	return 0;
}
