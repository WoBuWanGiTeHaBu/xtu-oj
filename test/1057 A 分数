#include<stdio.h>
long long gcd(long long a,long long b){
	long long q;
	q=a%b;
	while(q){
		a=b;
		b=q;
		q=a%b;
	}
	return b;
	
}


int main(){
	int n;
	scanf("%d",&n);
	while(n--){
		long long a,b,c;
		scanf("%lld %lld %lld",&a,&b,&c);
		long long sun=0,mum=0;
		sun=a*c-b*b;
		mum=b*c;
		long long g=gcd(sun,mum);
		sun/=g;
		mum/=g;
		sun=sun*a+c*mum;
		mum=mum*a;
		g=gcd(sun,mum);
		sun/=g;
		mum/=g;
		if(mum<0){
			mum=-mum;
			sun=-sun;
		}
		if(mum==1){
			printf("%lld\n",sun);
		
		}else{
			printf("%lld/%lld\n",sun,mum);
		}
		
	}
	
	return 0;
}
